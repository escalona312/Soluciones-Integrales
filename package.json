{
  "name": "soluciones-integrales-landing",
  "version": "1.0.0",
  "description": "Landing page para Soluciones Integrales - Constructor profesional en Angol",
  "scripts": {
    "check": "node ./scripts/check-site.mjs",
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify && npm run check",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "keywords": [
    "construccion",
    "angol",
    "landing-page",
    "tailwindcss"
  ],
  "author": "Soluciones Integrales",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
